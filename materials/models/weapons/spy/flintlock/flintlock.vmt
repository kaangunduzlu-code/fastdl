"VertexlitGeneric"
{
	"$baseTexture" "models/weapons/spy/flintlock/flintlock"
	"$bumpmap" "models/weapons/spy/flintlock/flintlock_normal"
	"$envmap" "env_cubemap"
	"$phong" "1"
	"$phongexponent" "15"
	"$phongboost" "2"	
	"$lightwarptexture" "models\lightwarps\weapon_lightwarp"
	"$phongfresnelranges"	"[.25 .5 1]"
	//"$basemapalphaphongmask" "1"

	"$rimlight" "1"
	"$rimlightexponent" "4"	
	"$rimlightboost" "1"

	"$glowcolor" "1"
	"360?$color2" "[ 0.9 0.8 0.8 ]"

	"$cloakPassEnabled" "1"

	"Proxies"
	{
		"vm_invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}

	}
}
