"VertexLitGeneric"
{
	"$basetexture" "vgui\replay\thumbnails\models\weapons\c_models\c_minigun\bunker_gun_gold01" //I KNOW THE ALPHA MASK FOR THE LIGHTS LOOKS LIKE TRASH SHUT UP ABOUT IT
	"$bumpmap" 	   "vgui\replay\thumbnails\models\weapons\c_models\c_minigun\bunker_gun01_normal"
	"$surfaceprop" "metal"
	"$envmapmask" "vgui\replay\thumbnails\models\weapons\c_models\c_minigun\bunker_gun01_mask"
	"$selfillum" 1

	"$phong"	"1"
	"$phongboost"	"0.5"
	"$phongfresnelranges"	"[1.6 4 9]"
	"$surfaceprop" "metal"
//	"$phongtint"				"[0.9 0.9 1]"

	"$glowcolor" "1"

	"$envmap" "cubemaps/cubemap_gold001"
	"$envmaptint" "[ .5 .5 .5]"	
	"$envmaptint" "[2.5 2.5 1.15]"
	
	"$basemapalphaphongmask" "1"
	
	"$rimlight" "1"						
	"$rimlightexponent" "20"				
	"$rimlightboost" ".5"

	"360?$color2" "[ 0.6 0.6 0.6 ]"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"$sheenPassEnabled" "1"

	"$sheenmap" 		"cubemaps/cubemap_sheen001"
	"$sheenmapmask" 		"Effects/AnimatedSheen/animatedsheen0"
	"$sheenmaptint" 		"[ 1 1 1 ]"
	"$sheenmapmaskframe" 	"0"
	"$sheenindex" 		"0"


	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}