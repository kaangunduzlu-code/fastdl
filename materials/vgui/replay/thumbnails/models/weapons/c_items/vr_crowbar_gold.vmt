"VertexLitGeneric"
{
	"$basetexture"	"vgui\replay\thumbnails\models\weapons\c_items\vr_crowbar_gold_d"
	"$bumpmap" 		"vgui\replay\thumbnails\models\weapons\c_items\vr_crowbar_nrm"
	
	"$phong"	"1"
	"$phongboost"	"0.5"
	"$phongfresnelranges"	"[1.6 4 9]"
	"$PhongExponentTexture"	"vgui\replay\thumbnails\models\weapons\c_items\vr_crowbar_exp"
	"$surfaceprop" "metal"
//	"$phongtint"				"[0.9 0.9 1]"


	"$envmap" "cubemaps/cubemap_gold001"	
	"$envmaptint" "[2.5 2.5 1.15]"

	"$rimlight" "1"						
	"$rimlightexponent" "70"				
	"$rimlightboost" ".25"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"$sheenPassEnabled" "1"

	"$sheenmap" 		"cubemaps\cubemap_sheen001"
	"$sheenmapmask" 		"Effects\AnimatedSheen\animatedsheen0"
	"$sheenmaptint" 		"[ 1 1 1 ]"
	"$sheenmapmaskframe" 	"0"
	"$sheenindex" 		"0"

	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}