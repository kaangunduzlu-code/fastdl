"VertexlitGeneric"
{
	"$baseTexture" "models\weapons\c_items/c_branding_iron"

	"$phong" "1"
	"$phongexponent" "60"
	"$phongboost" ".6"	
	"$lightwarptexture" "models\lightwarps\weapon_lightwarp"

	"$phongfresnelranges"	"[1.5 .8 3]"

	"$halflambert" "1"

	"$basemapalphaphongmask" "1"
	
	"$rimlight" "1"
	"$rimlightexponent" "10"	
	"$rimlightboost" "0.5"

	"$selfillum" "1"
	"$selfillummask" "models\weapons\c_items\c_branding_iron_mask"
	"$selfillumtint" "[ 2 .1 .3]"
	
	$selfillumtintmin "{95 95 95}"
	$selfillumtintmax "{110 110 110}"



	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"Proxies"
	{
		"weapon_invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		 "Sine"
		{
			"resultVar" "$selfillumtint"
			"sineperiod" "4"
			"sinemin" "$selfillumtintmin"
			"sinemax" "$selfillumtintmax"
		}
	}
}
