"VertexLitGeneric"
{
	"$basetexture"			"vgui\replay\thumbnails\models\weapons\c_items\vr_bugbait_inside"
	"$bumpmap"			"vgui\replay\thumbnails\models\weapons\c_items\vr_bugbait_inside_normal"

	"$envmap"			"env_cubemap"
//	"$normalmapalphaenvmapmask"	"1"
	"$envmaptint"			"[0.5 1 0.5]"

	"$phong"				"1"
	"$phongboost"			"1"
	"$phongexponent"			"1"

	"$surfaceprop"			"alienflesh"

 	// requred to see specular on dx6+7 at all
	"$multipass" 1

	"$glowcolor" "1"
// Cloaking

	"$cloakPassEnabled" "1"
	"$sheenPassEnabled" "1"

	"$sheenmap" 		"cubemaps/cubemap_sheen001"
	"$sheenmapmask" 		"Effects/AnimatedSheen/animatedsheen0"
	"$sheenmaptint" 		"[ 1 1 1 ]"
	"$sheenmapmaskframe" 	"0"
	"$sheenindex" 		"0"

	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	
	

	}
}