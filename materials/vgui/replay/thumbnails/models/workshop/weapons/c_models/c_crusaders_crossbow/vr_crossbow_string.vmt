"vertexlitgeneric"
{
	"$basetexture"			"vgui\replay\thumbnails\models\workshop\weapons\c_models\c_crusaders_crossbow\vr_crossbow_string"
	"$bumpmap"			"vgui\replay\thumbnails\models\workshop\weapons\c_models\c_crusaders_crossbow\vr_crossbow_string_normal"
	"$envmap"			"env_cubemap"
	"$normalmapalphaenvmapmask"	"1"

	"$phong"				"1"
	"$phongboost"			"2"
	"$phongexponent"			"12"
	"$phongfresnelranges"		"[0 0.5 1]"

	"$envmap" "env_cubemap"
	"$envmaptint" "[ .09 .09 .1]"
	"$normalmapalphaenvmapmask" "1"
	
	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"$sheenPassEnabled" "1"

	"$sheenmap" 		"cubemaps\cubemap_sheen001"
	"$sheenmapmask" 		"Effects\AnimatedSheen\animatedsheen0"
	"$sheenmaptint" 		"[ 1 1 1 ]"
	"$sheenmapmaskframe" 	"0"
	"$sheenindex" 		"0"

	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}